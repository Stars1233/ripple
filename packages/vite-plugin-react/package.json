{
  "name": "@tsrx/vite-plugin-react",
  "description": "Vite plugin for @tsrx/react (.tsrx modules)",
  "license": "MIT",
  "author": "Dominic Gannaway",
  "version": "0.0.16",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/vite-plugin-react"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
