{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["esnext"],
    "target": "esnext",
    "noEmit": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "strict": true,
    "checkJs": true,
    "types": ["node"]
  },
  "include": ["./src/**/*", "./tests/**/*", "./types/**/*"],
  "exclude": ["dist", "node_modules"]
}
