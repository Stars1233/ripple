{
  "name": "@tsrx/react",
  "description": "React compiler built on @tsrx/core",
  "license": "MIT",
  "author": "Dominic Gannaway",
  "version": "0.2.5",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripple-TS/ripple.git",
    "directory": "packages/tsrx-react"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./error-boundary": {
      "types": "./types/error-boundary.d.ts",
      "default": "./src/error-boundary.js"
    },
    "./ref": {
      "types": "./types/ref.d.ts",
      "default": "./src/ref.js"
    },
    "./runtime": {
      "types": "./types/runtime.d.ts",
      "default": "./src/runtime.js"
    }
  },
  "dependencies": {
    "@tsrx/core": "workspace:*",
    "esrap": "catalog:default",
    "zimmerframe": "catalog:default"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/estree": "catalog:default",
    "@types/estree-jsx": "catalog:default",
    "@types/react": "catalog:default",
    "typescript": "catalog:default"
  },
  "files": [
    "src",
    "types"
  ]
}
