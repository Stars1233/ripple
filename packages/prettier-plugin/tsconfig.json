{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "dom.iterable"],
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["./*.js", "./src/", "vitest-extensions.d.ts"],
  "exclude": ["node_modules", "dist"]
}
